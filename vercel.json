{
  "version": 2,
  "builds": [
    {
      "src": "Fitness_club/wsgi.py",
      "use": "@vercel/python",
      "config": {

        "runtime": "python3.13"
      }
    },
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "staticfiles"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "Fitness_club/wsgi.py"
    }
  ]
}